RB_DB_NAME=riobranco
RB_DB_USER=riobranco
RB_DB_PASSWORD=troque-esta-senha
RB_DB_ROOT_PASSWORD=troque-esta-senha-root
RB_DB_BIND=127.0.0.1

# Ambiente de execucao
# O padrao operacional eh manter mensagens no servidor e trabalhar na copia local.
# Se RB_EMAIL_DELETE_FROM_SERVER=1 em producao, apenas POP3 pode apagar apos
# validar conteudo e anexos locais; IMAP permanece sempre sem exclusao.
RB_ENV=homologacao
APP_ENV=homologacao
RB_EMAIL_DELETE_FROM_SERVER=0
RB_EMAIL_AUTO_IMPORT=1
RB_EMAIL_AUTO_INTERVAL_MINUTES=5
RB_EMAIL_AUTO_MAX_EMAILS=200
RB_EMAIL_BUSINESS_START=08:00
RB_EMAIL_BUSINESS_END=18:00
# 0=segunda ... 6=domingo
RB_EMAIL_BUSINESS_DAYS=0,1,2,3,4
RB_EMAIL_TIMEZONE=America/Sao_Paulo
RB_EMAIL_XML_MAX_FILE_MB=20
RB_EMAIL_XML_ZIP_MAX_ENTRIES=200
RB_EMAIL_XML_ZIP_MAX_TOTAL_MB=100
RB_EMAIL_XML_TRUSTED_SENDERS=bebidasriobranco8@gmail.com
RB_EMAIL_XML_TRUSTED_ZIP_MAX_ENTRIES=1000
RB_EMAIL_XML_LOCAL_BACKLOG_MAX_ATTACHMENTS=200
RB_EMAIL_BOL_ENABLED=0
RB_EMAIL_BOL_ACCOUNT_ID=2
RB_EMAIL_BOL_ACCOUNT_NAME=BOL Compras Materia Prima
RB_EMAIL_BOL_IMAP_HOST=imap.bol.com.br
RB_EMAIL_BOL_IMAP_PORT=993
RB_EMAIL_BOL_IMAP_SSL=1
RB_EMAIL_BOL_MAILBOX=INBOX
RB_EMAIL_BOL_SMTP_HOST=smtp.bol.com.br
RB_EMAIL_BOL_SMTP_PORT=587
RB_EMAIL_BOL_SMTP_TLS=1
RB_EMAIL_BOL_USER=
RB_EMAIL_BOL_PASS=
RB_EMAIL_BOL_SINCE_DATE=2026-01-01
RB_EMAIL_BOL_HISTORY_MAILBOXES=ALL
RB_EMAIL_BOL_FILTER_KEYWORDS=compra,compras,cotacao,pedido,materia prima,materia-prima,insumo,fornecedor,nfe,nf-e,xml
RB_EMAIL_BOL_STORAGE_LIMIT_GB=5

# HTTPS / certificados
# O padrao atual eh emissao automatica da CA e dos certificados do app e do FreePBX.
RB_ENABLE_HTTPS=1

# Use exatamente o IP ou DNS acessado pelos clientes.
RB_SERVER_NAME=192.168.200.254
RB_PUBLIC_BASE_URL=https://192.168.200.254
RB_PROJECT_NAME=RioBranco
RB_COMPANY_NAME=RioBranco
RB_COMPANY_CNPJ=20.984.401/0001-30
RB_INTERNAL_IP=

# O proxy e publicado em todas as interfaces para acesso pela rede.
RB_HTTP_PORT=80
RB_HTTPS_PORT=443
RB_DB_BACKUP_PATH=./backupsSql
RB_DB_RESTORE_FORCE=0

# Cert bootstrap
# Use 1 somente na VM "oficial" que deve configurar o certificado WSS do FreePBX compartilhado.
# Em homologacao ou outra VM apontando para o mesmo FreePBX, use 0.
RB_CERT_BOOTSTRAP=1
RB_CA_CERT_CN=RioBranco Internal CA
RB_CA_CERT_DAYS=3650
RB_SERVER_CERT_DAYS=825
RB_CERT_FORCE_REISSUE=0
RB_CERT_APP_HOSTS=192.168.200.254
RB_CERT_PBX_HOSTS=192.168.200.253,freepbx.sangoma.local,localhost,127.0.0.1

# Flask / monitor access
FLASK_SECRET=troque-esta-chave
UI_USER=admin
UI_PASS=troque-esta-senha-ui

# Agent IA / Ollama
# auto: tenta Ollama e cai para o agente local
# ollama: tenta Ollama e cai para o agente local se falhar
# none: desliga o uso de LLM
RB_AGENT_LLM_PROVIDER=auto
RB_MANAGED_OLLAMA=1
RB_MANAGED_OLLAMA_MODEL=qwen2.5:3b
RB_OLLAMA_REMOVE_MODELS=qwen2.5:7b
RB_OLLAMA_IMAGE=ollama/ollama:latest
RB_OLLAMA_BIND=127.0.0.1
RB_OLLAMA_PORT=11434
RB_AGENT_OLLAMA_URL=http://ollama:11434
RB_AGENT_OLLAMA_MODEL=qwen2.5:3b
RB_AGENT_OLLAMA_TIMEOUT=90
RB_AGENT_OLLAMA_TEMPERATURE=0.2

# Open WebUI usa o mesmo Ollama/Qwen do compose.
# Gere a chave com: openssl rand -hex 32
RB_OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.9.6
RB_OPEN_WEBUI_COMPAT_IMAGE=riob-open-webui:v0.9.6-numpy2.2.6
RB_OPEN_WEBUI_NUMPY_VERSION=2.2.6
RB_OPEN_WEBUI_PORT=3000
RB_OPEN_WEBUI_NAME=RioBranco IA
RB_OPEN_WEBUI_SECRET_KEY=troque-por-uma-chave-aleatoria-longa
RB_OPEN_WEBUI_ENABLE_SIGNUP=true
RB_OPEN_WEBUI_OFFLINE_MODE=true
RB_OPEN_WEBUI_HF_HUB_OFFLINE=1
RB_OPEN_WEBUI_OLLAMA_URL=http://ollama:11434
RB_OPEN_WEBUI_VOLUME=riob_open_webui_data

RB_AGENT_WEB_ENABLED=1
RB_AGENT_WEB_TIMEOUT=12
RB_AGENT_WEB_BUDGET=20

# ESXi monitor access
RB_VSPHERE_CLIENT_PATH=./esxi
ESXI_HOST=192.168.200.198
ESXI_USER=root
ESXI_PASS=troque-esta-senha-esxi
ESXI_SSH_PORT=22
ESXI_SSH_TIMEOUT=12

# Industrial automation monitor
RB_AUTOMACAO_MONITOR_PATH=../../automacao/source

# SIP / FreePBX bootstrap for browser WebRTC
RB_SIP_BOOTSTRAP_FORCE=0
RB_SIP_HABILITADO=1
RB_SIP_MODO_ATIVO=freepbx
RB_SIP_FREEPBX_WS_URL=wss://192.168.200.253:8089/ws
RB_SIP_FREEPBX_DOMINIO=192.168.200.253
RB_SIP_FREEPBX_REGISTRAR_SERVER=sip:192.168.200.253
RB_SIP_FREEPBX_OUTBOUND_PROXY=
RB_SIP_FREEPBX_PREFIXO_SAIDA=
RB_SIP_FREEPBX_CALLER_ID_TEMPLATE="{nome} RioBranco"
RB_SIP_FREEPBX_STUN_SERVERS=
RB_SIP_FREEPBX_TURN_URL=
RB_SIP_FREEPBX_TURN_USUARIO=
RB_SIP_FREEPBX_TURN_SENHA=
RB_SIP_FREEPBX_AUTO_REGISTER=1

# FreePBX / provisioning automation
RB_FREEPBX_HOST=192.168.200.253
RB_FREEPBX_SSH_PORT=22
RB_FREEPBX_SSH_USER=root
RB_FREEPBX_SSH_PASS=troque-esta-senha-freepbx
RB_FREEPBX_PJSIP_TRANSPORT=0.0.0.0-wss
RB_FREEPBX_PJSIP_ALLOW=ulaw,alaw
RB_FREEPBX_TRUNK_NAME=SeteVoIP
RB_FREEPBX_TRUNK_PROVIDER_DOMAIN=sip.setevoip.com.br
RB_FREEPBX_TRUNK_HOST=sip.setevoip.com.br
RB_FREEPBX_TRUNK_PORT=5060
RB_FREEPBX_TRUNK_FROMUSER=
RB_FREEPBX_TRUNK_USERNAME=
RB_FREEPBX_TRUNK_SECRET=
RB_FREEPBX_TRUNK_FROMDOMAIN=sip.setevoip.com.br
RB_FREEPBX_TRUNK_NAT=force_rport,comedia
RB_FREEPBX_TRUNK_DTMFMODE=rfc2833
RB_FREEPBX_TRUNK_INSECURE=invite,port
RB_FREEPBX_TRUNK_CANREINVITE=no
